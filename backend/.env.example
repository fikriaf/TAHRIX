# ──────────────────────────────────────────────────────────
# TAHRIX Backend — Environment Variables (example)
# Copy to `.env` and fill in real credentials.
# ──────────────────────────────────────────────────────────

# ── App ──
APP_ENV=development                 # development | staging | production
APP_NAME=TAHRIX
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Security ──
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL (Supabase / local) ──
DATABASE_URL=postgresql+asyncpg://tahrix:tahrix@localhost:5432/tahrix

# ── Neo4j AuraDB ──
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ── Redis (Upstash / local) ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Alchemy (Ethereum / Base / Polygon) ──
ALCHEMY_API_KEY=
ALCHEMY_ETH_URL=https://eth-mainnet.g.alchemy.com/v2/
ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/
ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2/

# ── Helius (Solana) ──
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
HELIUS_API_URL=https://api-mainnet.helius-rpc.com
HELIUS_WEBHOOK_AUTH_HEADER=
HELIUS_WEBHOOK_SECRET=

# ── Etherscan V2 (multichain unified) ──
ETHERSCAN_API_KEY=
ETHERSCAN_API_URL=https://api.etherscan.io/v2/api

# ── Chainalysis Sanctions (free tier) ──
CHAINALYSIS_API_KEY=
CHAINALYSIS_API_URL=https://public.chainalysis.com/api/v1/address

# ── LayerZero Scan (public) ──
LAYERZERO_SCAN_URL=https://scan.layerzero-api.com/v1
LAYERZERO_OFT_API_KEY=

# ── Wormhole Scan (public) ──
WORMHOLESCAN_API_URL=https://api.wormholescan.io/api/v1

# ── IPFS (Infura) ──
INFURA_IPFS_PROJECT_ID=
INFURA_IPFS_PROJECT_SECRET=
INFURA_IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_PUBLIC_GATEWAY=https://ipfs.io/ipfs

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── LLM (Agent reasoning) ──
LLM_PROVIDER=openai                 # openai | anthropic | local
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000

# ── GNN Inference ──
GNN_MODEL_PATH=./ml/artifacts/gat_elliptic.onnx
GNN_FEATURE_DIM=165
GNN_THRESHOLD=0.5

# ── Risk Scorer Weights ──
RISK_W_GNN=0.40
RISK_W_ANOMALY=0.30
RISK_W_SANCTIONS=0.20
RISK_W_CENTRALITY=0.10

# ── Investigation defaults ──
INVESTIGATION_DEFAULT_HOPS=3
INVESTIGATION_MAX_HOPS=5
INVESTIGATION_MAX_ITERATIONS=5
INVESTIGATION_CONFIDENCE_THRESHOLD=0.85

# ── Rate limiting ──
RATE_LIMIT_FREE=100/minute
RATE_LIMIT_ANALYST=1000/minute
